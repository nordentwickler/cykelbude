<!DOCTYPE html>
<!--
webhub.de
-->
<html lang="{{ craft.app.language }}">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, minimum-scale=1, maximum-scale=5, user-scalable=yes">
    <link rel="home" href="{{ siteUrl }}"/>
    {# Preload fonts #}
    {# <link rel="preload" as="font" type="font/woff2" href="/assets/fonts/Switzer-Variable.woff2"/> #}
    {# SEO-Tags einfangen; wenn kein eigenes Social-Bild gesetzt ist (og:image
       leer), unser dynamisch generiertes Share-Bild der Seite einsetzen. #}
    {% set seoTags %}{% hook 'seo' %}{% endset %}
    {% set injectOg = entry is defined and entry and entry.id is defined and ('property="og:image" content=""' in seoTags) %}
    {% if injectOg %}
        {% set ogImage = url('og/' ~ entry.id) %}
        {% set seoTags = seoTags
            | replace({
                'property="og:image" content=""': 'property="og:image" content="' ~ ogImage ~ '"',
                'name="twitter:image" content=""': 'name="twitter:image" content="' ~ ogImage ~ '"'
            }) %}
    {% endif %}
    {{ seoTags|raw }}
    {% if injectOg %}<meta property="og:image:type" content="image/png">{% endif %}
    {{ craft.vite.script('src/scripts/app.js', false) }}
    {% set settings = craft.entries.section('settings').with(['footerNavigation', 'mainNavigation']).one() %}
</head>

<body {{ craft.app.config.general.devMode ? 'data-dev-mode="true"' }}>

    <div id="app" class="bg-navy text-white overflow-x-hidden">
        <div id="site-content" class="p-4 lg:p-8 transition-transform duration-300 ease-in-out min-h-screen">
            {% include '_layouts/partials/header.twig' ignore missing %}

            <main class="space-y-24 lg:space-y-48 xl:my-64">
                {% block content %}
                    <p class="text-center">If you see this, no block named content was provided.</p>
                {% endblock %}
            </main>

            {% include '_layouts/partials/footer.twig' ignore missing %}
        </div>

        <nav class="fixed top-0 right-0 h-full w-72 md:w-80 lg:w-96 bg-pink text-white z-50 flex flex-col items-end justify-start translate-x-full transition-transform duration-300 ease-in-out p-6 md:p-8 lg:p-10 overflow-y-auto overscroll-contain" id="mobile-navigation" aria-label="Hauptnavigation" aria-hidden="true">
            <div class="flex flex-col text-right justify-end items-end gap-12 lg:gap-24">

                <div>
                    <button id="menu-close" class="text-white hover:bg-navy focus:outline-2 focus:outline-white focus:outline-offset-4 p-2 inline-flex rounded-lg cursor-pointer" aria-label="Menü schließen">
                        {{ craft.vite.inline('@assets/icons/close.svg')|attr({
                            class: 'h-8 sm:h-13 w-auto fill-current'
                        }) }}
                    </button>
                </div>

                <ul class="space-y-6 lg:space-y-8" role="list">
                    {% for entry in settings.mainNavigation %}
                    <li>
                        <a href="{{ entry.getUrl }}"
                        class="text-white hover:text-navy font-display focus:outline-2 focus:outline-white focus:outline-offset-4 p-2 text-4xl md:text-5xl">
                            {{ entry.title }}
                        </a>
                    </li>
                    {% endfor %}
                </ul>

                <ul class="lg:mt-8">
                    {% for entry in settings.footerNavigation.all() %}
                        <li><a href="{{ entry.getUrl }}" class="text-2xl lg:text-3xl hover:text-navy focus:outline-2 focus:outline-white">{{ entry.title }}</a> </li>
                    {% endfor %}
                </ul>
            </div>
        </nav>
    </div>

    {# Craft CSRF token #}
    {% include '_inline-scripts/_craft-csrf-token' %}

</body>
</html>

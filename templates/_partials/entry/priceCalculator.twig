<section class="container">
    {% if entry.headline %}
        <div class="lg:max-w-4/5">
            <h2 class="mb-6">{{ entry.headline }}</h2>
        </div>
    {% endif %}
    <div id="price-calculator" class="w-full">
        <div id="calculator-content" class="bg-white rounded-2xl border border-navy/10 shadow-lg p-5 lg:p-8">

            <div class="grid grid-cols-1 lg:grid-cols-5 gap-6">

                {# Karte + Route #}
                <div class="lg:col-span-3">
                    <div class="relative">
                        <div id="map" class="w-full h-[60dvh] lg:h-[60dvh] rounded-lg border border-navy/10"></div>
                        <div id="map-hint" class="absolute top-3 left-3 right-3 bg-navy text-white p-3 rounded-lg text-center font-bold text-base shadow-lg pointer-events-none">
                            Tippe zuerst deinen Abholort an
                        </div>
                    </div>

                    {# Legende #}
                    <div class="mt-3 flex flex-wrap items-center gap-x-5 gap-y-1 text-sm text-navy/70">
                        <span class="flex items-center gap-2"><span class="h-4 w-4 rounded-full bg-pink border-2 border-white shadow"></span> Abholung</span>
                        <span class="flex items-center gap-2"><span class="h-4 w-4 rounded-full bg-navy border-2 border-white shadow"></span> Stop</span>
                    </div>
                    <p class="mt-2 text-sm text-navy/50">Die genaue Adresse ist für den Preis nicht nötig - es zählt nur das Gebiet. Deine exakte Adresse gibst du erst später bei der Bestellung an.</p>
                </div>

                {# Panel (daneben, mobil darunter): Zustellzeit + Preis #}
                <div class="lg:col-span-2 space-y-4">
                    {# Zustellzeit #}
                    <div class="md:border border-navy/10 md:rounded-lg md:p-5">
                        <span class="block text-lg font-bold text-navy mb-3">Zustellzeit</span>
                        <div id="delivery-time-options" role="radiogroup" aria-label="Zustellzeit" class="flex w-full rounded-lg border-2 border-navy overflow-hidden">
                            {# Wird per JS befüllt #}
                        </div>
                    </div>

                    <p id="price-empty" class="border border-navy/10 rounded-lg p-5 text-base text-navy/60">
                        Sobald Abholort und mindestens ein Stop gesetzt sind, erscheint hier der Preis.
                    </p>
                    <div id="price-section" class="hidden space-y-4">
                        <div class="md:border border-navy/10 md:rounded-lg md:p-5 text-navy">
                            <h4 class="text-xl font-bold text-navy mb-3">Zusammensetzung</h4>
                            <div id="price-breakdown" class="space-y-2 text-base"></div>
                        </div>
                        <div class="bg-pink text-white rounded-lg p-6">
                            <span class="block text-sm uppercase tracking-[0.2em] text-white/80 mb-2">Gesamtpreis</span>
                            <span id="price-brutto" class="block font-display leading-none text-6xl xl:text-7xl">0,00 €</span>
                            <div class="mt-5 flex items-center justify-between border-t border-white/30 pt-4 text-base">
                                <span id="vat-label" class="text-white/80">inkl. MwSt.</span>
                                <span id="price-vat" class="font-bold">0,00 €</span>
                            </div>
                        </div>
                        <button type="button" id="order-request-btn" class="w-full bg-navy text-white py-4 px-6 font-bold rounded-lg hover:bg-navy/80 transition-colors">
                            Lieferung anfragen
                        </button>
                    </div>
                </div>

            </div>
        </div>

        {% include '_partials/forms/delivery.twig' %}
    </div>
</section>

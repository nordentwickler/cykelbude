<div class=" grid grid-cols-1 justify-between w-full items-center">
    <div class="text-center lg:pt-24">
        <div class="relative">
            <h1 class="claim-one font-display text-5xl sm:text-6xl lg:text-9xl xl:text-10xl absolute top-0 -translate-y-1/2 left-1/2 -translate-x-1/2 z-100 text-white">CYKELBUDE</h1>
                <div class="aspect-square md:max-w-[740px] bg-mint mx-auto relative overflow-hidden" data-hero-slideshow>
                    {% if entry.images %}
                        {% set images = entry.images.eagerly() %}
                        {% set transform = { width: 740, height: 740, mode: 'crop', format: 'webp' } %}
                        {% for image in images %}
                            {# Anzeigebreite: mobil 100vw minus Padding (Seite p-4 +
                               Hero px-8 = 96px), ab ~840px auf 740px gedeckelt
                               (md:max-w-[740px]). w-Deskriptoren + sizes statt
                               1.5x/2x, damit mobil nicht das 1480er Bild lädt. #}
                            {{ tag('img', {
                                src: image.getUrl(transform),
                                width: 740,
                                height: 740,
                                srcset: image.getSrcset(['400w', '600w', '740w', '900w', '1480w'], transform),
                                sizes: '(min-width: 840px) 740px, calc(100vw - 96px)',
                                alt: image.alt,
                                fetchpriority: loop.first ? 'high' : null,
                                loading: loop.first ? 'eager' : 'lazy',
                                decoding: 'async',
                                class: "absolute inset-0 w-full h-full object-cover " ~ (loop.first ? "z-10" : "z-0")
                            }) }}
                        {% endfor %}
                    {% endif %}
                </div>
            <span class="claim-one font-display text-5xl sm:text-6xl lg:text-9xl xl:text-10xl absolute bottom-0 translate-y-1/2 left-1/2 -translate-x-1/2 z-100 text-white">KURIERKOLLEKTIV</span>

        </div>

        <div class="max-w-[720px] mx-auto mt-24 lg:mt-48">
            <p class="text-white  font-sans">{{ entry.simpleText }}</p>
        </div>
    </div>

    {% if entry.buttons is defined and entry.buttons|length %}
        <div class="flex flex-wrap justify-center gap-4 py-8">
            {% for entry in entry.buttons  %}
                {% include '_partials/entry/button.twig' with {
                    variant: 'navy'
                }%}
            {% endfor %}
        </div>
    {% endif %}


</div>


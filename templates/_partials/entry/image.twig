{% set asset = entry.image.eagerly().one() %}
{% if asset %}
    {% set transform = { width: 800, format: 'webp', quality: 80 } %}
    {{ tag('img', {
        src: asset.getUrl(transform),
        width: asset.width,
        height: asset.height,
        srcset: asset.getSrcset(['400w', '600w', '800w', '1200w'], transform),
        sizes: '(min-width: 768px) 50vw, 100vw',
        alt: asset.alt,
        loading: 'lazy',
        decoding: 'async',
        class: 'rounded-lg'
    }) }}
{% endif %}

<div class="container">

<div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 lg:gap-6 my-12 lg:mb-36">
{% for logo in entry.logos.eagerly() %}
    <div class="flex items-center justify-center aspect-3/2 bg-white p-5 md:p-8 rounded-lg" data-aos="fade-up">
        {% if logo.extension|lower == 'svg' %}
            {# SVGs sind vektorbasiert und lassen sich nicht (zu WebP)
               transformieren - das Original unverändert ausliefern. #}
            {{ tag('img', {
                src: logo.url,
                width: logo.width,
                height: logo.height,
                alt: logo.alt,
                loading: 'lazy',
                decoding: 'async',
                class: "w-full h-full object-contain"
            }) }}
        {% else %}
            {# Reale Bildbreite = Spalte - Grid-Gaps - Seiten-Padding - Box-Padding.
               Die calc()-Werte ziehen die festen Paddings ab, damit sizes nicht
               (wie bei reinem vw) zu große Kandidaten anfordert. Deckel: ~360px. #}
            {% set transform = { width: 360, format: 'webp' } %}
            {{ tag('img', {
                src: logo.getUrl(transform),
                width: logo.width,
                height: logo.height,
                srcset: logo.getSrcset(['180w', '270w', '360w'], transform),
                sizes: '(min-width: 1024px) calc(25vw - 98px), (min-width: 640px) calc(33vw - 59px), calc(50vw - 62px)',
                alt: logo.alt,
                loading: 'lazy',
                decoding: 'async',
                class: "w-full h-full object-contain"
            }) }}
        {% endif %}
    </div>
{% endfor %}
</div>
</div>

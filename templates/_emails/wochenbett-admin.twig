<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body style="margin:0; padding:0; background-color:#f4f4f6;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#f4f4f6; padding:32px 0;">
        <tr>
            <td align="center">
                <table role="presentation" width="600" cellpadding="0" cellspacing="0" style="max-width:600px; width:100%; background-color:#ffffff; border-radius:12px; overflow:hidden; font-family:Arial,Helvetica,sans-serif;">
                    <tr>
                        <td style="background-color:#e6007e; padding:28px 32px;">
                            <h1 style="margin:0; color:#ffffff; font-size:22px; line-height:1.3;">Neue Wochenbett-Wunder Anfrage</h1>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:32px;">
                            <p style="margin:0 0 24px; color:#1f2440; font-size:16px; line-height:1.6;">
                                Über die Website ist eine neue Anfrage eingegangen:
                            </p>

                            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="border-collapse:collapse;">
                                {% for fieldName, field in def.fields %}
                                    {% set value = values[fieldName] ?? '' %}
                                    {% if value is not empty %}
                                        {% if field.boolean is defined %}{% set value = 'Ja' %}{% endif %}
                                        <tr>
                                            <td style="padding:12px 0; border-bottom:1px solid #ececf0; color:#8a8a99; font-size:13px; text-transform:uppercase; letter-spacing:0.04em; vertical-align:top; width:42%;">{{ field.label }}</td>
                                            <td style="padding:12px 0 12px 16px; border-bottom:1px solid #ececf0; color:#1f2440; font-size:16px; vertical-align:top;">{{ value|nl2br }}</td>
                                        </tr>
                                    {% endif %}
                                {% endfor %}
                            </table>

                            <p style="margin:28px 0 0; color:#8a8a99; font-size:13px; line-height:1.6;">
                                Antwort auf diese E-Mail geht direkt an die anfragende Person.
                                Die Anfrage liegt außerdem im CMS unter &bdquo;Anfragen&ldquo;.
                            </p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>
